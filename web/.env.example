# =====================================================
# WEB FRONTEND ENVIRONMENT VARIABLES
# Copy file này thành .env.local và điền giá trị thật
# KHÔNG commit .env.local lên git
# =====================================================

# Firebase Client Config (từ Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Google Maps JavaScript API Key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Backend API URL
# Local dev: dùng proxy (/api) → đã config trong vite.config.js
# Production: đổi thành Cloud Run URL
VITE_API_BASE_URL=/api
